# ── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000

# ── Database (Supabase Postgres via Supavisor) ─────────────────────────────────
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Transaction" mode URL (port 6543) for serverless / connection-pooled deployments
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ── Supabase ───────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Get from: Supabase Dashboard → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── Storage Buckets (optional — defaults used if not set) ─────────────────────
SUPABASE_BUCKET_RESUMES=resumes
SUPABASE_BUCKET_COMPANY_LOGOS=company-logos
SUPABASE_BUCKET_JOB_ATTACHMENTS=job-attachments

# ── Redis (Phase 2 — required when BullMQ queues are enabled) ─────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
