# ── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000

# ── Auth (self-managed JWT) ────────────────────────────────────────────────────
# Secret used to sign access tokens (use a long random string in production).
JWT_SECRET=change-me-in-production
# Optional dedicated secret for refresh tokens (falls back to JWT_SECRET if unset).
JWT_REFRESH_SECRET=change-me-too-in-production

# ── Email / SMTP (optional — auth code emails; fails open if not configured) ────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
SMTP_FROM=no-reply@jobfit.local

# ── Database (Supabase Postgres via Supavisor) ─────────────────────────────────
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Transaction" mode URL (port 6543) for serverless / connection-pooled deployments
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# ── Supabase ───────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Get from: Supabase Dashboard → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── Storage Buckets (optional — defaults used if not set) ─────────────────────
SUPABASE_BUCKET_RESUMES=resumes
SUPABASE_BUCKET_COMPANY_LOGOS=company-logos
SUPABASE_BUCKET_JOB_ATTACHMENTS=job-attachments

# ── Redis (Phase 2 — required when BullMQ queues are enabled) ─────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# ── Observability (monitoring plan Phases 0–4) ────────────────────────────────
# Logging (Phase 0): LOG_FORMAT=json in staging/prod → GCP Cloud Logging.
LOG_LEVEL=debug                 # trace|debug|info|warn|error|fatal|silent
LOG_FORMAT=pretty               # pretty (dev) | json (prod)

# Service identity (Phase 2 — Error Reporting serviceContext). SERVICE_VERSION → git SHA
# at build; falls back to Cloud Run K_REVISION → 'local'.
SERVICE_NAME=jobfit-backend
SERVICE_VERSION=

# Metrics & tracing (Phase 3).
METRICS_ENABLED=true
METRICS_TOKEN=                  # SECRET — when set, /metrics requires this bearer token
TRACE_ENABLED=false             # true on Cloud Run → OpenTelemetry → Cloud Trace
GCP_PROJECT_ID=                 # for Cloud Trace + log↔trace correlation

# Alerting (Phase 4). Enables Slack alerts; in-app system_events are always written.
SLACK_WEBHOOK_URL=              # SECRET

# External heartbeat (Healthchecks.io dead-man's-switch). App pings this URL while healthy;
# if it crashes / DB is down, pings stop (or hit /fail) and Healthchecks.io alerts. Unset = off.
HEALTHCHECKS_PING_URL=          # SECRET — e.g. https://hc-ping.com/<uuid>
HEALTHCHECKS_INTERVAL_SECONDS=60

# Job ingestion (FR-JOBS-001). TheMuse public jobs API key (optional; leave blank to run unauthenticated).
THEMUSE_API_KEY=          # get one free at https://www.themuse.com/developers/api/v2

# ── AI service (jobfits-ai-service) ──────────────────────────────────────────
# The backend is the only caller of the AI service; it never reaches Ollama directly.
# AI_SERVICE_URL is the versioned base — it MUST include the /api/v1 prefix.
AI_SERVICE_URL=http://localhost:8000/api/v1
AI_SERVICE_KEY=change-me
AI_TIMEOUT_MS_GENERATE=60000
AI_TIMEOUT_MS_EMBED=10000
