generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  JOB_SEEKER
  EMPLOYER
  ADMIN
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  SCREENING
  INTERVIEW
  OFFER
  ACCEPTED
  NEGOTIATING
  REJECTED
  WITHDRAWN
  ARCHIVED
}

// ── Shared-kernel enums (Phase 3) ────────────────────────────────────────────
enum SubscriptionTier {
  FREE
  PREMIUM
  PROFESSIONAL
}

enum JobLevel {
  INTERN
  ENTRY
  MID
  SENIOR
  LEAD
  MANAGER
  DIRECTOR
  C_LEVEL
}

enum RemoteType {
  ON_SITE
  HYBRID
  REMOTE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  FREELANCE
}

enum DegreeLevel {
  HIGH_SCHOOL
  ASSOCIATE
  BACHELOR
  MASTER
  DOCTORATE
  CERTIFICATION
}

// ── Admin module enums (Admin MVP) ───────────────────────────────────────────
// NOTE: the admin docs spell these lowercase (e.g. 'health_check'); we follow this
// project's existing convention of UPPERCASE Prisma enum members (see UserRole above).

enum SystemEventType {
  HEALTH_CHECK
  API_LATENCY_HIGH
  ERROR_RATE_HIGH
  QUEUE_BACKED_UP
  EMAIL_DELIVERY_LOW
  DATABASE_ERROR
}

enum SystemEventSeverity {
  INFO
  WARNING
  CRITICAL
}

enum EmailEventType {
  SENT
  DELIVERED
  BOUNCED_SOFT
  BOUNCED_HARD
  COMPLAINED
  UNSUBSCRIBED
}

enum AuditActionType {
  USER_RESET_PASSWORD
  USER_ACCOUNT_DELETED
  USER_UNLOCKED
  EMAIL_SUPPRESSED
}

enum AuditResourceType {
  USER
  EMAIL
  SYSTEM
}

// ── Employer module enums (Employer Phase 2) ─────────────────────────────────
// How a company's ownership was verified. Two methods only (docs' simplified scope):
// email-domain match, or manual admin review.
enum CompanyVerificationMethod {
  EMAIL_DOMAIN
  ADMIN_REVIEW
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  name             String           @default("")
  passwordHash     String           @default("")
  role             UserRole         @default(JOB_SEEKER)
  subscriptionTier SubscriptionTier @default(FREE)
  avatarUrl        String?
  isActive         Boolean          @default(true)

  // Email verification (isVerified in the domain maps to this column)
  emailVerified          Boolean   @default(false)
  verificationCode       String?
  verificationCodeExpiry DateTime?

  // Password reset (6-digit code flow — see Flow 0.3)
  passwordResetCode       String?
  passwordResetCodeExpiry DateTime?

  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Job seeker profile (legacy — kept for job/application/company modules)
  jobSeekerProfile JobSeekerProfile?
  // Employer profile
  employerProfile  EmployerProfile?
  // Auth sessions
  refreshTokens    RefreshToken[]

  // ── User module (Phase 3) ──────────────────────────────────────────────────
  profile        Profile?
  experiences    Experience[]
  educations     Education[]
  certifications Certification[]
  skills         UserSkill[]
  analytics      UserAnalytics?
  resumes        Resume[]
  applications   Application[]
  savedJobs      SavedJob[]

  // ── Admin module (Admin MVP) ───────────────────────────────────────────────
  // Admin actions this user performed / system alerts this admin acknowledged.
  auditLogs                AuditLog[]    @relation("AdminAuditLogs")
  acknowledgedSystemEvents SystemEvent[] @relation("AcknowledgedSystemEvents")

  // ── Employer module (Employer Phase 2) ─────────────────────────────────────
  // Jobs this employer posted, applications they reviewed, and pipeline moves they made.
  postedJobs             Job[]                     @relation("PostedByEmployer")
  reviewedApplications   Application[]             @relation("ReviewedByEmployer")
  movedApplicationStages ApplicationStageHistory[] @relation("MovedByUser")

  @@index([email])
  @@index([role])
  @@index([subscriptionTier])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SHA-256 hash of the refresh token — plaintext is never stored.
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  // Soft-delete for rotation: NULL = live, non-null = consumed/revoked (kept so a
  // replayed already-rotated token can be detected as reuse/theft).
  revokedAt DateTime?

  @@index([userId])
  @@index([tokenHash])
  @@index([userId, revokedAt])
  @@map("refresh_tokens")
}

// ── User module (Phase 3) ──────────────────────────────────────────────────────

model Profile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName String
  lastName  String
  phone     String?
  photoUrl  String?
  bio       String?
  headline  String? // e.g. "Senior Software Engineer at Google"

  // Location
  city      String?
  state     String?
  country   String?
  latitude  Float?
  longitude Float?

  // Work preferences
  desiredJobLevels       JobLevel[]
  desiredRemoteTypes     RemoteType[]
  desiredEmploymentTypes EmploymentType[]
  desiredIndustries      String[] // Industry IDs

  // Salary
  minSalary      Int?
  maxSalary      Int?
  salaryCurrency String @default("USD")

  // Social links
  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@map("profiles")
}

model Experience {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  company        String
  title          String
  jobLevel       JobLevel
  employmentType EmploymentType
  industry       String // Industry ID

  description  String?
  isCurrentJob Boolean @default(false)

  startDate DateTime
  endDate   DateTime?

  technologies String[] // tech used

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([company])
  @@map("experiences")
}

model Education {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  institution  String
  degreeLevel  DegreeLevel
  fieldOfStudy String
  description  String?

  startDate DateTime
  endDate   DateTime?
  gpa       Float?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([institution])
  @@map("educations")
}

model Certification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  issuer        String
  credentialId  String?
  credentialUrl String?

  issueDate      DateTime
  expirationDate DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@map("certifications")
}

model UserSkill {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  skillId String
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Restrict)

  endorsementCount  Int    @default(0)
  proficiencyLevel  String @default("INTERMEDIATE") // BEGINNER, INTERMEDIATE, ADVANCED, EXPERT
  yearsOfExperience Float?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
  @@map("user_skills")
}

model UserAnalytics {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalApplications         Int   @default(0)
  totalInterviews           Int   @default(0)
  totalOffers               Int   @default(0)
  applicationAcceptanceRate Float @default(0)
  interviewAcceptanceRate   Float @default(0)

  profileViewCount    Int       @default(0)
  lastProfileViewDate DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@map("user_analytics")
}

model JobSeekerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  bio       String?
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matchScores MatchScore[]

  @@map("job_seeker_profiles")
}

model EmployerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employer_profiles")
}

model Company {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  website     String?
  logoUrl     String?
  industry    String? // Industry ID
  size        String? // STARTUP | SMALL | MEDIUM | LARGE | ENTERPRISE
  foundedYear Int?

  // Location
  city    String?
  state   String?
  country String?

  // Glassdoor data
  glassdoorId      String?
  glassdoorRating  Float?
  glassdoorReviews Int?

  // ── Employer module: ownership verification (Employer Phase 2) ──────────────
  isVerified         Boolean                    @default(false)
  verificationMethod CompanyVerificationMethod?
  verifiedAt         DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  employers EmployerProfile[]
  jobs      Job[]

  // NOTE: Prisma's @@fulltext is MySQL-only and invalid on PostgreSQL. Company search is
  // implemented with case-insensitive `contains` in the repository; for production-grade
  // full-text search add a tsvector GIN index via a raw migration and switch to $queryRaw.
  @@index([name])
  @@index([industry])
  @@index([isVerified])
  @@map("companies")
}

model Job {
  id          String    @id @default(uuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title       String
  description String
  status      JobStatus @default(DRAFT)
  remoteType  String // e.g. "REMOTE", "HYBRID", "ON_SITE"
  location    String?
  minSalary   Int?
  maxSalary   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ── Employer module (Employer Phase 2) ──────────────────────────────────────
  // Employer (user) who posted this job. NULL = external/ingested job (no employer).
  postedByEmployerId String?
  postedByEmployer   User?   @relation("PostedByEmployer", fields: [postedByEmployerId], references: [id], onDelete: SetNull)

  applications Application[]
  matchScores  MatchScore[]
  skills       JobSkill[]
  savedBy      SavedJob[]

  @@index([postedByEmployerId])
  @@map("jobs")
}

// A job a seeker bookmarked for later. Simple join of (user, job); unique so a
// job can't be saved twice, cascade so it disappears if either side is deleted.
model SavedJob {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@map("saved_jobs")
}

enum ResumeParsingStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

model Resume {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fileName String
  fileUrl  String
  fileSize Int
  fileType String // "PDF" | "DOCX"

  title     String?
  isDefault Boolean @default(false)

  parsingStatus ResumeParsingStatus @default(PENDING)
  parsingError  String?

  atsScore     Int?
  qualityScore Int?
  version      Int  @default(1)

  parsedData   ParsedResumeData?
  applications Application[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([isDefault])
  @@index([parsingStatus])
  @@map("resumes")
}

model ParsedResumeData {
  id       String @id @default(uuid())
  resumeId String @unique
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  fullName String?
  email    String?
  phone    String?
  location String?

  summary        String?
  experiences    String? // JSON string
  educations     String? // JSON string
  skills         String? // JSON string
  certifications String? // JSON string
  rawText        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("parsed_resume_data")
}

model Application {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId  String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  resumeId String?
  resume   Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  status      ApplicationStatus @default(SUBMITTED)
  appliedAt   DateTime          @default(now())
  notes       String?
  coverLetter String?

  // ── Employer module: pipeline review (Employer Phase 2) ─────────────────────
  employerNotes        String?
  reviewedByEmployerId String?
  reviewedByEmployer   User?   @relation("ReviewedByEmployer", fields: [reviewedByEmployerId], references: [id], onDelete: SetNull)

  timeline      ApplicationTimeline[]
  contactPerson ContactPerson?
  stageHistory  ApplicationStageHistory[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, jobId])
  @@index([userId])
  @@index([status])
  @@index([reviewedByEmployerId])
  @@map("applications")
}

// ── Employer module: application pipeline stage history (Employer Phase 2) ─────
// One row per pipeline transition. Reuses ApplicationStatus (not a separate pipeline
// enum) to stay consistent with the rest of the system.
model ApplicationStageHistory {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  previousStatus ApplicationStatus?
  newStatus      ApplicationStatus

  movedByUserId String?
  movedByUser   User?   @relation("MovedByUser", fields: [movedByUserId], references: [id], onDelete: SetNull)

  notes     String?
  createdAt DateTime @default(now())

  @@index([applicationId])
  @@index([createdAt])
  @@map("application_stage_history")
}

model ApplicationTimeline {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  status      ApplicationStatus
  eventType   String
  description String?
  eventDate   DateTime          @default(now())

  @@index([applicationId])
  @@map("application_timelines")
}

model ContactPerson {
  id            String      @id @default(uuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  name        String
  email       String?
  phone       String?
  title       String?
  linkedinUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_persons")
}

model MatchScore {
  id                 String           @id @default(uuid())
  jobId              String
  job                Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  score              Float // 0 - 100
  breakdown          Json? // sub-scores e.g. skill, experience
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([jobId, jobSeekerProfileId])
  @@map("match_scores")
}

model Skill {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs       JobSkill[]
  userSkills UserSkill[]

  @@map("skills")
}

model JobSkill {
  jobId   String
  job     Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skillId String
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
  @@map("job_skills")
}

model Industry {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("industries")
}

// ── Admin module models (Admin MVP) ──────────────────────────────────────────

/// System health alerts (Feature 1). Emitted by monitoring / health checks; admins
/// can acknowledge them from the dashboard.
model SystemEvent {
  id        String              @id @default(uuid())
  eventType SystemEventType
  severity  SystemEventSeverity @default(INFO)
  message   String
  details   Json? // structured payload: latency_ms, endpoint, error_count, ...

  acknowledgedAt        DateTime?
  acknowledgedByAdminId String?
  acknowledgedByAdmin   User?     @relation("AcknowledgedSystemEvents", fields: [acknowledgedByAdminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([severity])
  @@index([createdAt])
  @@index([acknowledgedAt])
  @@map("system_events")
}

/// Email delivery events (Feature 3). Fed by the email provider (SendGrid/SES) webhook.
/// `notificationId` is a soft reference kept for future linkage — there is no
/// notifications table yet, so it is a plain nullable column (no FK).
model EmailEvent {
  id              String         @id @default(uuid())
  recipientEmail  String
  notificationId  String?
  eventType       EmailEventType
  reason          String? // for bounces/complaints: why it failed
  externalEventId String? // provider event id (SendGrid/SES)

  createdAt DateTime @default(now())

  @@index([recipientEmail])
  @@index([createdAt])
  @@index([eventType])
  @@map("email_events")
}

/// Basic admin action log (Audit Logging). Intentionally minimal for the MVP —
/// no old/new values, IP, or free-text reason (Phase 2+).
model AuditLog {
  id           String            @id @default(uuid())
  adminId      String
  admin        User              @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: Cascade)
  actionType   AuditActionType
  resourceType AuditResourceType
  resourceId   String? // user id or email address the action targeted

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@map("audit_logs")
}
